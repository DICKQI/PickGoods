# ==================== SHIGU 后端环境变量 ====================
# 复制此文件为 .env 并填入你自己的值
# .env 已加入 .gitignore，不会被提交到 Git

# --- Django ---
# Django 密钥，用于 session/CSRF/签名等
# 生成方式：python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key-here

# --- JWT ---
# JWT 签名密钥（可选，默认使用 DJANGO_SECRET_KEY）
# 生成方式：python -c "import secrets; print(secrets.token_hex(32))"
# JWT_SECRET=your-jwt-secret-here

# --- Bangumi API ---
# BGM.tv Access Token（可选，不设置则无法使用 BGM 搜索/关联功能）
# 获取方式：https://bgm.tv/dev/app 创建应用后获取
# BGM_ACCESS_TOKEN=your-bgm-access-token-here
